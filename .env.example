REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REPORT_QUEUE_NAME=reports
REPORT_DATABASE_URL=postgresql+psycopg://reports:reports@postgres:5432/reports
REPORT_UPLOADS_DIR=/data/uploads
REPORT_RESULTS_DIR=/data/results
REPORT_WORK_DIR=/data/work
RQ_JOB_TIMEOUT_SECONDS=3600
RQ_RESULT_TTL_SECONDS=86400
RQ_FAILURE_TTL_SECONDS=604800
CLEANER_CRON_SCHEDULE=0 * * * *
CLEANER_UPLOADS_TTL_HOURS=1
CLEANER_WORK_TTL_HOURS=1
POSTGRES_DB=reports
POSTGRES_USER=reports
POSTGRES_PASSWORD=reports
